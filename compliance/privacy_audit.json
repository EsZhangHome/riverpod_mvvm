{
  "schemaVersion": 1,
  "sourceRoots": [
    "lib",
    "android/app/src/main",
    "ios/Runner",
    "config"
  ],
  "allowedPermissions": [
    {
      "name": "android.permission.INTERNET",
      "purpose": "访问项目配置的 HTTPS 后端接口"
    },
    {
      "name": "android.permission.ACCESS_NETWORK_STATE",
      "purpose": "监听网络是否连接，用于断网提示；不读取设备身份信息"
    }
  ],
  "forbiddenPermissions": [
    "android.permission.READ_PHONE_STATE",
    "android.permission.READ_PHONE_NUMBERS",
    "android.permission.QUERY_ALL_PACKAGES",
    "android.permission.READ_SMS",
    "android.permission.READ_CALL_LOG",
    "android.permission.WRITE_CALL_LOG",
    "android.permission.READ_CONTACTS",
    "android.permission.WRITE_CONTACTS",
    "android.permission.ACCESS_BACKGROUND_LOCATION",
    "android.permission.MANAGE_EXTERNAL_STORAGE"
  ],
  "allowedExportedComponents": [
    {
      "name": ".MainActivity",
      "purpose": "Android Launcher 入口；必须导出才能响应系统 MAIN/LAUNCHER Intent",
      "requiredPermission": ""
    },
    {
      "name": "androidx.profileinstaller.ProfileInstallReceiver",
      "purpose": "AndroidX ProfileInstaller 接收系统/开发工具的基线配置安装命令",
      "requiredPermission": "android.permission.DUMP"
    }
  ],
  "allowedDomains": [
    {
      "host": "api.example.com",
      "purpose": "未传入编译环境时使用的模板地址",
      "placeholder": true
    },
    {
      "host": "dev-api.example.com",
      "purpose": "模板开发环境接口",
      "placeholder": true
    },
    {
      "host": "test-api.example.com",
      "purpose": "模板测试环境接口",
      "placeholder": true
    },
    {
      "host": "privacy.example.com",
      "purpose": "底座开发环境隐私协议与用户协议模板地址",
      "placeholder": true
    },
    {
      "host": "replace-with-production-api.invalid",
      "purpose": "提醒接入方替换正式环境域名",
      "placeholder": true
    },
    {
      "host": "replace-with-staging-api.invalid",
      "purpose": "提醒接入方替换预发布环境域名",
      "placeholder": true
    },
    {
      "host": "replace-with-privacy-policy.invalid",
      "purpose": "提醒接入方替换正式隐私政策地址",
      "placeholder": true
    },
    {
      "host": "replace-with-user-agreement.invalid",
      "purpose": "提醒接入方替换正式用户协议地址",
      "placeholder": true
    }
  ],
  "sensitiveApis": [
    {
      "id": "android_id",
      "name": "Android ID",
      "severity": "blocker",
      "patterns": [
        "Settings.Secure.ANDROID_ID",
        "Settings$Secure;->ANDROID_ID",
        "\"android_id\"",
        "'android_id'"
      ],
      "binaryPatterns": [
        "android_id",
        "ANDROID_ID"
      ],
      "dexPatterns": [
        "android\\.provider\\.Settings\\$Secure .* ANDROID_ID"
      ],
      "remediation": "不要在底座或三方 SDK 中静默读取 Android ID；确有业务必要时先完成合规评估、告知同意和 SDK 清单登记。"
    },
    {
      "id": "telephony_identifier",
      "name": "IMEI/MEID/IMSI 等电话标识",
      "severity": "blocker",
      "patterns": [
        "getDeviceId(",
        "getImei(",
        "getMeid(",
        "getSubscriberId("
      ],
      "binaryPatterns": [],
      "dexPatterns": [
        "android\\.telephony\\.TelephonyManager .* (getDeviceId|getImei|getMeid|getSubscriberId)\\("
      ],
      "remediation": "删除硬件标识采集。设备风控应使用经法务确认的合规方案，并遵循最小必要原则。"
    },
    {
      "id": "device_serial",
      "name": "设备序列号",
      "severity": "blocker",
      "patterns": [
        "Build.getSerial(",
        "Build.SERIAL"
      ],
      "binaryPatterns": [],
      "dexPatterns": [
        "android\\.os\\.Build .* (getSerial\\(| SERIAL)"
      ],
      "remediation": "不要读取设备序列号；多数普通业务不需要该信息。"
    },
    {
      "id": "installed_apps",
      "name": "已安装应用列表",
      "severity": "blocker",
      "patterns": [
        "getInstalledPackages(",
        "getInstalledApplications(",
        "QUERY_ALL_PACKAGES"
      ],
      "binaryPatterns": [
        "QUERY_ALL_PACKAGES"
      ],
      "dexPatterns": [
        "android\\.(app\\.ApplicationPackageManager|content\\.pm\\.PackageManager) .* (getInstalledPackages|getInstalledApplications)\\("
      ],
      "remediation": "删除安装列表读取；如属于应用商店允许的核心场景，需要单独审批并在隐私政策中逐项说明。"
    },
    {
      "id": "advertising_identifier",
      "name": "广告标识符",
      "severity": "review",
      "patterns": [
        "AdvertisingIdClient",
        "getAdvertisingIdInfo(",
        "IdentifierForAdvertising"
      ],
      "binaryPatterns": [
        "AdvertisingIdClient",
        "getAdvertisingIdInfo",
        "IdentifierForAdvertising"
      ],
      "dexPatterns": [
        "com\\.google\\.android\\.gms\\.ads\\.identifier\\.AdvertisingIdClient"
      ],
      "remediation": "确认是否真的需要广告标识，并核对同意时机、关闭个性化广告后的行为和隐私政策披露。"
    },
    {
      "id": "oaid",
      "name": "OAID",
      "severity": "review",
      "patterns": [
        "MdidSdk",
        "MSAHelper",
        "getOAID(",
        "getOaid("
      ],
      "binaryPatterns": [
        "MdidSdk",
        "MSAHelper",
        "getOAID",
        "getOaid"
      ],
      "dexPatterns": [],
      "remediation": "核对 OAID SDK 的版本、初始化时机、采集目的和隐私政策披露。"
    },
    {
      "id": "wifi_identifier",
      "name": "Wi-Fi 标识信息",
      "severity": "review",
      "patterns": [
        "getMacAddress(",
        "getBSSID(",
        "getSSID("
      ],
      "binaryPatterns": [],
      "dexPatterns": [
        "android\\.net\\.wifi\\.WifiInfo .* (getMacAddress|getBSSID|getSSID)\\("
      ],
      "remediation": "确认是否读取 MAC、BSSID 或 SSID；普通联网判断不应依赖这些标识。"
    },
    {
      "id": "clipboard",
      "name": "剪贴板内容",
      "severity": "review",
      "patterns": [
        "getPrimaryClip(",
        "hasPrimaryClip(",
        "Clipboard.getData("
      ],
      "binaryPatterns": [
        "Clipboard.getData"
      ],
      "dexPatterns": [
        "android\\.content\\.ClipboardManager .* (getPrimaryClip|hasPrimaryClip)\\("
      ],
      "remediation": "只在用户明确触发粘贴时读取剪贴板，并避免在启动阶段或后台静默读取。"
    },
    {
      "id": "secure_settings_access",
      "name": "Android Secure Settings",
      "severity": "review",
      "patterns": [
        "Settings.Secure.getString(",
        "Settings.Secure.getInt("
      ],
      "binaryPatterns": [],
      "dexPatterns": [
        "android\\.provider\\.Settings\\$Secure .* (getString|getInt)\\("
      ],
      "remediation": "逐项确认读取的键。读取系统开关不等于读取 Android ID，但仍应避免用通用封装隐藏敏感键。"
    }
  ],
  "approvedFindings": [
    {
      "ruleId": "secure_settings_access",
      "pathContains": "permission_handler_android",
      "reason": "permission_handler_android 仅用它判断系统定位开关；升级插件版本后必须重新复核。"
    }
  ],
